# Database (Supabase PostgreSQL)
# Get this from your Supabase project settings -> Database -> Connection String (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# If you prefer not to modify the URL, you can set the environment variable instead:
# PGSSLMODE=require

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# Server
PORT=3001

# Supabase Storage (for file attachments)
# Get these from Supabase project settings -> API
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="project-attachments"
